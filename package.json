{
  "name": "icey-client",
  "productName": "Icey Client",
  "version": "1.21.0",
  "description": "A premium Minecraft launcher with an icy theme",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.iceyclient.app",
    "productName": "Icey Client",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "mod/build/libs/iceymod-*.jar"
    ],
    "mac": {
      "category": "public.app-category.games",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "icon": "src/assets/icon.png",
      "artifactName": "Icey Client-${arch}.${ext}",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": ["portable"],
      "icon": "src/assets/icon.png",
      "artifactName": "Icey Client.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "src/assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "src/assets/icon.png",
      "uninstallerIcon": "src/assets/icon.png"
    }
  }
}
